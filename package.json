{
  "name": "needlescript",
  "description": "Logo inspired programming language for generative embroidery",
  "private": true,
  "author": "Fredi Bach",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build": "tsc -b && vite build",
    "build:lib": "tsdown && node scripts/make-publish-package.mjs",
    "check:lib": "publint ./dist-lib && attw --pack ./dist-lib --ignore-rules cjs-resolves-to-esm",
    "release:lib": "npm run build:lib && npm test && npm run check:lib",
    "format": "prettier --write .",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "doctor": "npx react-doctor@latest",
    "knip": "knip",
    "e18e": "npx @e18e/cli analyze"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clipper2-ts": "2.0.1-17",
    "clsx": "^2.1.1",
    "delaunator": "5.1.0",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.53.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.12.0",
    "simplex-noise": "4.0.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/js": "^10.0.1",
    "@types/delaunator": "5.0.3",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.21",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "knip": "^6.21.0",
    "prettier": "^3.9.0",
    "prettier-config-airbnb": "^1.0.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
